// MyVisa — Prisma v6 schema (do not upgrade to v7 without rewriting the
// `url` datasource into a driver adapter + prisma.config.ts).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A paid visa application — doubles as the admin "customer" record and the
/// dashboard "application" (with its timeline, documents, and messages).
model Application {
  id              String   @id @default(cuid())
  ref             String   @unique // e.g. MV-48213
  title           String? // dashboard application name, e.g. "Schengen Tourist Visa"
  // applicant
  fullName        String
  email           String
  phone           String?
  dob             String?
  gender          String? // Erkek | Kadın | Diğer
  nationality     String
  nationalityFlag String // ISO-2 code for flagcdn, e.g. "ng"
  passport        String?
  passportExpiry  String? // passport valid-until date
  employment      String? // Çalışan | Serbest meslek | İşsiz | Emekli | Öğrenci
  // address
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  // trip
  destination     String
  destinationFlag String // ISO-2 code, e.g. "us" / "eu"
  visaType        String
  purpose         String?
  sponsor         String? // Kendim | Aile | Ev sahibi | İşveren
  accommodation   String? // Otel | Ev sahibi
  hasChildren     Boolean  @default(false)
  travelDate      String?
  duration        String?
  // commercial
  plan            String   @default("Standard") // Basic | Standard | Premium
  persons         Int      @default(1) // group size for tiered pricing
  perPerson       String? // per-person fee, e.g. "€335"
  amount          String // total price (display), e.g. "€375"
  totalCents      Int      @default(0) // total price in cents, for payment math
  govFee          String? // "$185.00"
  paymentMethod   String? // "Visa •••• 4242"
  txn             String? // "txn_9f2a71c4"
  paidOn          String? // "18 Jun 2026"
  visaCenter      String? // applicant's chosen visa application centre (city)
  status          String   @default("Pending") // Pending | DepositPaid | Paid (fully) | Refunded
  statusIndex     Int      @default(0) // 0..4 timeline position (see statuses[])
  isDemo          Boolean  @default(false) // seeded demo rows shown on the dashboard
  createdAt       DateTime @default(now())

  documents Document[]
  messages  Message[]
  payments  Payment[]

  @@index([email])
  @@index([status])
}

/// A document attached to an application checklist. Bytes are stored in the DB
/// (portable for this deploy; swap for object storage at scale).
model Document {
  id            String      @id @default(cuid())
  name          String
  state         String // Verified | In review | Action needed | Missing
  mimeType      String? // e.g. "application/pdf"
  size          Int? // bytes
  data          Bytes? // file contents (null for seeded/placeholder docs)
  uploadedBy    String      @default("customer") // customer | specialist
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
}

/// A status/specialist message on an application timeline.
model Message {
  id            String      @id @default(cuid())
  who           String
  when          String
  text          String
  fromCustomer  Boolean     @default(false)
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
}

/// A message submitted from the public Contact page.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

/// Durable outbound-notification queue (transactional outbox). A notification is
/// enqueued, delivered best-effort immediately, and retried with backoff by a
/// drainer if delivery fails — so alerts are never lost when Telegram is down.
model Notification {
  id          String    @id @default(cuid())
  channel     String    @default("telegram") // telegram | (future: email, slack…)
  payload     String // the message body to send
  status      String    @default("pending") // pending | sending | sent | failed
  attempts    Int       @default(0)
  lastError   String?
  nextAttempt DateTime  @default(now()) // earliest time to (re)try
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextAttempt])
}

/// A single payment against an application. Split-payment model: a "deposit"
/// (50%) is taken at checkout, and a "balance" (remaining 50%) is created by an
/// admin once the appointment is booked, then paid by the customer.
model Payment {
  id            String      @id @default(cuid())
  kind          String // deposit | balance
  label         String // e.g. "Kapora (%50)" / "Bakiye (%50)"
  amountCents   Int
  status        String      @default("pending") // pending | paid | refunded
  txn           String?
  paidOn        String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String

  @@index([applicationId])
}

/// One-time login codes for customer email verification (OTP). The code itself
/// is never stored — only an HMAC hash. Short-lived, single-use, attempt-capped.
model LoginCode {
  id        String   @id @default(cuid())
  email     String // lowercased
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}
