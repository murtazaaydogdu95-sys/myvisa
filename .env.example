# Local Postgres (Docker container `myvisa-pg` on host port 5433)
DATABASE_URL="postgresql://myvisa:myvisa@localhost:5433/myvisa?schema=public"

# Admin login (gate at /admin, see src/middleware.ts)
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me"

# Secret used to sign auth cookies (HMAC). Falls back to ADMIN_PASSWORD if unset.
AUTH_SECRET="generate-a-long-random-string"

# Email (Resend). If RESEND_API_KEY is unset, emails are skipped (logged only).
RESEND_API_KEY=""
EMAIL_FROM="MyVisa <onboarding@resend.dev>"
ADMIN_EMAIL=""            # where contact-form notifications go

# Public base URL (used by sitemap)
SITE_URL="https://myvisa.aydex.nl"
