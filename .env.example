# Local Postgres (Docker container `myvisa-pg` on host port 5433)
DATABASE_URL="postgresql://myvisa:myvisa@localhost:5433/myvisa?schema=public"

# Admin login (gate at /admin, see src/middleware.ts)
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me"

# Secret used to sign auth cookies (HMAC). Falls back to ADMIN_PASSWORD if unset.
AUTH_SECRET="generate-a-long-random-string"

# Email (Resend). If RESEND_API_KEY is unset, emails are skipped (logged only).
RESEND_API_KEY=""
EMAIL_FROM="MyVisa <onboarding@resend.dev>"
ADMIN_EMAIL=""            # where contact-form notifications go

# Telegram purchase alerts. If either is unset, sends are skipped (logged only).
# Create a bot via @BotFather to get the token; get the chat id from @userinfobot
# (DM) or a group's chat id. Both must be set to enable notifications.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Secret guarding the notification-outbox drainer endpoint
# (/api/cron/flush-notifications). The k8s CronJob calls it every 2 min.
# If unset, the cron endpoint is disabled (queue still drains opportunistically
# on each new application). Use a long random string in production.
CRON_SECRET=""

# Public base URL (used by sitemap)
SITE_URL="https://myvisa.aydex.nl"
